{
  "name": "cashsync",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "bootstrap:infra": "docker compose up -d db redis",
    "bootstrap:backend": "cd backend && npm install && npm run prisma:generate && npm run prisma:seed",
    "bootstrap:frontend": "cd frontend && npm install",
    "bootstrap": "bash scripts/bootstrap.sh",
    "lint": "npm run lint:backend:fix && npm run lint:frontend",
    "lint:check": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "npm --prefix backend run lint",
    "lint:backend:fix": "npm --prefix backend run lint:fix",
    "lint:frontend": "npm --prefix frontend run lint"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^9.25.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-native": "^4.0.0"
  }
}
