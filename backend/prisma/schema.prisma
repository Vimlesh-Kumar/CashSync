generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// USER & AUTH
// ─────────────────────────────────────────────

model User {
  id         String  @id @default(uuid())
  email      String  @unique
  name       String?
  avatarUrl  String?
  password   String? // Optional — only for JWT/email auth
  provider   String  @default("JWT") // GOOGLE | APPLE | JWT
  providerId String? // OAuth subject ID (optional for JWT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authProviders   AuthProvider[]
  transactions  Transaction[]
  transactionSources TransactionSource[]
  memberships   GroupMember[]
  splits        Split[]
  categoryRules CategoryRule[] // user-defined auto-tag rules
  smsTemplates  SmsTemplate[] // user-saved SMS parser templates
  categories    Category[]
  budgets       Budget[]
  people        Person[]

  @@map("users")
}

model AuthProvider {
  id             String   @id @default(uuid())
  userId         String
  provider       String // GOOGLE | APPLE
  providerUserId String
  email          String?
  emailVerified  Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
  @@index([userId])
  @@map("auth_providers")
}

// ─────────────────────────────────────────────
// GROUPS & SPLITTING
// ─────────────────────────────────────────────

model Group {
  id          String   @id @default(uuid())
  name        String
  description String?
  emoji       String? // e.g. "🏖" for "Goa Trip"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members      GroupMember[]
  transactions Transaction[]

  @@map("groups")
}

model GroupMember {
  id       String   @id @default(uuid())
  userId   String
  groupId  String
  role     String   @default("MEMBER") // ADMIN | MEMBER
  joinedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@map("group_members")
}

// ─────────────────────────────────────────────
// TRANSACTIONS
// ─────────────────────────────────────────────

model Transaction {
  id       String   @id @default(uuid())
  title    String
  note     String? // User-editable memo / renamed label
  amount   Float
  currency String   @default("INR")
  date     DateTime @default(now())

  // Classification
  type     String @default("EXPENSE") // EXPENSE | INCOME | TRANSFER
  category String @default("General") // auto-tagged or manual
  source   String @default("MANUAL") // MANUAL | SMS | EMAIL | API
  categoryId String?

  // Deduplication fingerprinting
  sourceId String? // original reference/txn ID from bank
  hash     String? // composite fingerprint for dedup

  // Privacy
  isPersonal Boolean @default(true)
  reviewState String @default("UNREVIEWED") // UNREVIEWED | PERSONAL | SPLIT

  // Renaming history
  originalTitle String? // stores the raw bank SMS/email title

  // Relations
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  groupId String?
  group   Group?  @relation(fields: [groupId], references: [id])
  categoryRef Category? @relation("TransactionCategory", fields: [categoryId], references: [id])

  splits Split[]
  sources TransactionSource[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([hash])
  @@index([authorId, date])
  @@index([authorId, reviewState])
  @@map("transactions")
}

// ─────────────────────────────────────────────
// SPLITTING
// ─────────────────────────────────────────────

model Split {
  id            String @id @default(uuid())
  transactionId String
  userId        String

  amountOwed Float
  amountPaid Float     @default(0.0)
  isSettled  Boolean   @default(false)
  settledAt  DateTime?

  splitMethod String @default("EQUAL") // EQUAL | EXACT | PERCENT | SHARES

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id])

  @@index([transactionId])
  @@map("transaction_splits")
}

// ─────────────────────────────────────────────
// SMART CATEGORIZATION
// ─────────────────────────────────────────────

// User-defined + system rules for auto-tagging
model CategoryRule {
  id       String @id @default(uuid())
  userId   String
  pattern  String // regex or keyword e.g. "SWIGGY|ZOMATO"
  category String // e.g. "Food & Drinks"
  priority Int    @default(0) // higher = checked first

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("category_rules")
}

model Category {
  id        String   @id @default(uuid())
  userId    String
  name      String
  icon      String?
  color     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[] @relation("TransactionCategory")
  budgets      Budget[]

  @@unique([userId, name])
  @@index([userId])
  @@map("categories")
}

model Budget {
  id          String   @id @default(uuid())
  userId      String
  categoryId  String?
  categoryLabel String?
  name        String
  amount      Float
  spent       Float    @default(0.0)
  currency    String   @default("INR")
  monthStart  DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, monthStart])
  @@map("budgets")
}

model Person {
  id        String   @id @default(uuid())
  userId    String
  name      String
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("people")
}

model TransactionSource {
  id              String   @id @default(uuid())
  transactionId   String
  userId          String
  source          String // SMS | EMAIL | API | MANUAL
  sourceTxnId     String?
  fingerprintHash String?
  rawPayload      String?
  receivedAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([userId, source])
  @@unique([source, sourceTxnId, userId])
  @@map("transaction_sources")
}

// ─────────────────────────────────────────────
// SMS PARSING
// ─────────────────────────────────────────────

model SmsTemplate {
  id          String  @id @default(uuid())
  userId      String
  bankName    String
  pattern     String // regex template
  amountKey   String // capture group name
  typeKey     String // DEBIT | CREDIT keyword
  merchantKey String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("sms_templates")
}

model SmsLog {
  id         String   @id @default(uuid())
  rawSms     String
  parsedJson String? // JSON of extracted fields
  success    Boolean
  createdAt  DateTime @default(now())
  @@map("sms_logs")
}
