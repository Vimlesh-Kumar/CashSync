# =============================================
# CashSync Backend — Environment Variables
# =============================================
# Copy this file to .env and fill in real values.
# NEVER commit your actual .env file to Git.
# =============================================

# --- Database ---
# Full PostgreSQL connection string (provided by your cloud host, e.g. Railway)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public"

# PostgreSQL individual credentials (used by docker-compose)
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="change-me-strong-password"
POSTGRES_DB="cashsync"
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# --- Auth ---
# Generate a strong secret:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-byte-hex-secret

# --- Redis ---
# Redis connection string (provided by your cloud host, e.g. Railway)
REDIS_URL=redis://localhost:6379

# --- OAuth ---
# Google OAuth Client ID(s) — comma-separated if multiple platforms
GOOGLE_CLIENT_IDS=your-google-client-id.apps.googleusercontent.com

# Apple Sign-In Service ID
APPLE_CLIENT_IDS=com.yourcompany.cashsync

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:8081,https://your-frontend-domain.com

# --- Environment ---
# Set to PRODUCTION in prod, leave unset or DEV for local
ENV_CONTEXT=DEV
NODE_ENV=development
