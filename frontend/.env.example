# =============================================
# CashSync Frontend — Environment Variables
# =============================================
# Copy this file to .env and fill in real values.
# NEVER commit your actual .env file to Git.
# All EXPO_PUBLIC_ variables are bundled into the app — do NOT put secrets here.
# =============================================

# --- API ---
# Your deployed backend URL (Railway, Render, etc.)
# For local dev: http://localhost:3000/api
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# --- Google OAuth ---
# Web Client ID from Google Cloud Console
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# --- Apple Sign In ---
# Service ID from Apple Developer Console
EXPO_PUBLIC_APPLE_CLIENT_ID=com.yourcompany.cashsync
